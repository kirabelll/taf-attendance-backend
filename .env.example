# ==============================================
# TAF Attendance System - Environment Variables
# ==============================================
# Copy this file to .env and update with your values

# ==============================================
# Database Configuration
# ==============================================
POSTGRES_DB=taf_attendance
POSTGRES_USER=taf_user
POSTGRES_PASSWORD=changeme123

# ==============================================
# Django Configuration
# ==============================================
DJANGO_SECRET_KEY=your-secret-key-change-in-production-use-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=*

# ==============================================
# ZKBio Time 9.0 Configuration (REQUIRED)
# ==============================================
BIOTIME_URL=http://172.16.10.250:8002
BIOTIME_USERNAME=admin
BIOTIME_PASSWORD=your-password
BIOTIME_API_VERSION=v1

# ==============================================
# ERPNext Configuration (OPTIONAL)
# ==============================================
ERPNEXT_URL=http://your-erpnext-server:8080
ERPNEXT_API_KEY=your-api-key
ERPNEXT_API_SECRET=your-api-secret
ERPNEXT_VERSION=14

# ==============================================
# Integration Mode
# ==============================================
# Options: biotime, erpnext, both
INTEGRATION_MODE=biotime

# ==============================================
# Sync Settings
# ==============================================
SYNC_INTERVAL_MINUTES=1
MAX_RETRIES=3
BATCH_SIZE=100

# ==============================================
# Logging Configuration
# ==============================================
LOG_LEVEL=INFO
LOG_FILE=zk_erpnext_sync.log
LOGS_DIRECTORY=logs

# ==============================================
# Frontend Configuration
# ==============================================
VITE_API_URL=http://localhost:8005

# ==============================================
# ZK Device Configuration (for direct mode)
# ==============================================
ZK_DEVICE_1_IP=172.16.10.210
ZK_DEVICE_1_ID=Machine_1
ZK_DEVICE_1_PORT=4370
ZK_DEVICE_1_PUNCH_DIRECTION=AUTO
ZK_DEVICE_1_CLEAR_ON_FETCH=false
ZK_DEVICE_1_LATITUDE=0.0000
ZK_DEVICE_1_LONGITUDE=0.0000
ZK_DEVICE_PASSWORD=0
ZK_DEVICE_TIMEOUT=60

# ==============================================
# Webhook Configuration (OPTIONAL)
# ==============================================
WEBHOOK_PORT=8080
WEBHOOK_SECRET=your-webhook-secret-key
WEBHOOK_PATH=/webhook/attendance
